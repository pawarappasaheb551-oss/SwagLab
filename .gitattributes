# Automatically normalize line endings for all text files
* text=auto

# Force line endings for specific file types
*.java    text eol=lf
*.xml     text eol=lf
*.properties text eol=lf
*.sh      text eol=lf
*.bat     text eol=crlf

# Ignore binary files for line ending normalization
*.png     binary
*.jpg     binary
*.gif     binary
*.ico     binary
*.jar     binary
*.exe     binary
